Description: Set custom build ID and signing keys. DO NOT push to git — local only.
Build ID appears in ro.lineage.version as 23.2-YYYYMMDD-UNOFFICIAL-krab-v2.0a-athena.
Keys are stored in /data4/LOS23-build/signing-keys/ with unique certificates per role
(platform, media, bluetooth, nfc, sdk_sandbox, networkstack, shared, testkey).

File: device/blackberry/athena/device.mk
Signing keys directory: /data4/LOS23-build/signing-keys/

diff --git a/device/blackberry/athena/device.mk b/device/blackberry/athena/device.mk
--- a/device/blackberry/athena/device.mk
+++ b/device/blackberry/athena/device.mk
@@ -15,6 +15,12 @@

 DEVICE_PATH := device/blackberry/athena

+# Build ID
+TARGET_UNOFFICIAL_BUILD_ID := krab-v2.0a
+
+# Signing keys
+PRODUCT_DEFAULT_DEV_CERTIFICATE := /data4/LOS23-build/signing-keys/releasekey
+
 # Vendor blobs
 $(call inherit-product, vendor/blackberry/athena/athena-vendor.mk)
