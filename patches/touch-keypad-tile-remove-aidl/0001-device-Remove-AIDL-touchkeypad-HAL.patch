From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: user <user@localhost>
Date: Thu, 13 Mar 2026 14:30:00 +0000
Subject: [PATCH] device: Remove AIDL touchkeypad HAL

Remove AIDL HAL plumbing for touchkeypad: FCM entry, sepolicy
hal_touchkeypad.te, and file_contexts service entry.
Also remove vendor.blackberry.touchkeypad-service from device.mk.

diff --git a/framework_compatibility_matrix.xml b/framework_compatibility_matrix.xml
index 29f5e56..dfb2a58 100755
--- a/framework_compatibility_matrix.xml
+++ b/framework_compatibility_matrix.xml
@@ -1,53 +1,45 @@
 <compatibility-matrix version="1.0" type="framework">
     <hal format="hidl" optional="true">
         <name>android.hardware.vibrator</name>
         <version>1.0-1</version>
         <interface>
             <name>IVibrator</name>
             <instance>default</instance>
         </interface>
     </hal>
 
     <hal format="hidl">
         <name>vendor.goodix.hardware.fingerprint.hwbinder</name>
         <version>2.1</version>
         <interface>
             <name>IGoodixBiometricsFingerprint</name>
             <instance>default</instance>
         </interface>
     </hal>
 
     <hal format="hidl">
         <name>vendor.goodix.hardware.fingerprint</name>
         <version>1.0</version>
         <interface>
             <name>IGoodixBiometricsFingerprint</name>
             <instance>default</instance>
         </interface>
     </hal>
 
     <hal format="hidl">
         <name>android.hardware.radio</name>
         <transport>hwbinder</transport>
         <version>1.4</version>
         <interface>
             <name>IRadio</name>
             <instance>slot1</instance>
             <instance>slot2</instance>
         </interface>
         <interface>
             <name>ISap</name>
             <instance>slot1</instance>
             <instance>slot2</instance>
         </interface>
     </hal>
 
-    <hal format="aidl" optional="true">
-        <name>vendor.blackberry.touchkeypad</name>
-        <version>1</version>
-        <interface>
-            <name>ITouchKeypad</name>
-            <instance>default</instance>
-        </interface>
-    </hal>
 </compatibility-matrix>
diff --git a/sepolicy/vendor/file_contexts b/sepolicy/vendor/file_contexts
index dd741ff..c80a0e1 100644
--- a/sepolicy/vendor/file_contexts
+++ b/sepolicy/vendor/file_contexts
@@ -1,40 +1,37 @@
 # Cutback
 /data/vendor/misc/cutback(/.*)?     u:object_r:cutback_data_file:s0
 /dev/socket/cutback                 u:object_r:cutback_socket:s0
 
 # Files in rootfs
 /bt_firmware(/.*)?       u:object_r:bt_firmware_file:s0
 /firmware(/.*)?          u:object_r:firmware_file:s0
 /persist(/.*)?           u:object_r:mnt_vendor_file:s0
 
 # Fingerprint
 /dev/goodix_fp                                                u:object_r:gx_fpd_device:s0
 /data/system/fingerprint(/.*)?                                u:object_r:gx_fpd_data_file:s0
 /(vendor|system/vendor)/bin/gx_fpd                            u:object_r:gx_fpd_exec:s0
 
 # MAC Loader
 /(vendor|system/vendor)/bin/vendor.blackberry.macloader         u:object_r:macloader_exec:s0
 
 # NFC
 /(vendor|system/vendor)/bin/hw/android.hardware.nfc-service.nxp         u:object_r:hal_nfc_default_exec:s0
 
 # Lights service
 /(vendor|system/vendor)/bin/hw/android.hardware.lights-service.blackberry                   u:object_r:hal_light_default_exec:s0
 
 # Touch (GloveMode) service
 /(vendor|system/vendor)/bin/hw/vendor.lineage.touch@1.0-service.blackberry      u:object_r:hal_lineage_touch_default_exec:s0
 
-# TouchKeypad service
-/(vendor|system/vendor)/bin/hw/vendor.blackberry.touchkeypad-service            u:object_r:hal_touchkeypad_exec:s0
-
 # Partitions (Non-A/B)
 /dev/block/platform/soc/c0c4000\.sdhci/by-name/storesec                        u:object_r:boot_block_device:s0
 
 # tombstones
 /data/vendor/tombstones/rfs(/.*)?      u:object_r:rfs_tombstone_data_file:s0
 
 # FocalTech NavKeys
 /sys/board_properties/virtualkeys\.fts_input_device_B    u:object_r:sysfs_virtualkeys:s0
 
 # Widevine
 /(vendor|system/vendor)/bin/hw/android.hardware.drm@1.0-service.widevine        u:object_r:hal_drm_widevine_exec:s0
diff --git a/sepolicy/vendor/hal_touchkeypad.te b/sepolicy/vendor/hal_touchkeypad.te
deleted file mode 100644
index 053074f..0000000
--- a/sepolicy/vendor/hal_touchkeypad.te
+++ /dev/null
@@ -1,12 +0,0 @@
-type hal_touchkeypad, domain;
-type hal_touchkeypad_exec, exec_type, vendor_file_type, file_type;
-
-init_daemon_domain(hal_touchkeypad)
-hal_server_domain(hal_touchkeypad, hal_lineage_touch)
-
-allow hal_touchkeypad sysfs_touch_keypad:file rw_file_perms;
-allow hal_touchkeypad sysfs_touch_keypad:dir r_dir_perms;
-allow hal_touchkeypad sysfs_touch_keypad:lnk_file read;
-allow hal_touchkeypad default_android_service:service_manager add;
-binder_use(hal_touchkeypad)
-binder_call(platform_app, hal_touchkeypad)
-- 
2.34.1
