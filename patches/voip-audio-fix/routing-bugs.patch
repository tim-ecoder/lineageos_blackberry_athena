diff --git a/hal/audio_hw.c b/hal/audio_hw.c
index 2546eb1bfa..796ebb099f 100644
--- a/hal/audio_hw.c
+++ b/hal/audio_hw.c
@@ -5126,7 +5126,14 @@ int route_output_stream(struct stream_out *out,
                                                 out->handle);
             }
             if (!bypass_a2dp) {
-                select_devices(adev, out->usecase);
+                /* Don't override BT SCO voice routing with non-call stream routing */
+                if (adev->bt_sco_on && voice_is_in_call(adev) &&
+                    !output_drives_call(adev, out)) {
+                    ALOGD("%s: BT SCO active during call, skipping select_devices for usecase %d",
+                          __func__, out->usecase);
+                } else {
+                    select_devices(adev, out->usecase);
+                }
             } else {
                 if (compare_device_type(&new_devices, AUDIO_DEVICE_OUT_SPEAKER_SAFE))
                     reassign_device_list(&out->device_list, AUDIO_DEVICE_OUT_SPEAKER_SAFE, "");
@@ -8916,6 +8923,12 @@ static int adev_set_parameters(struct audio_hw_device *dev, const char *kvpairs)
          }
          else {
             adev->bt_sco_on = false;
+            if (voice_is_in_call(adev) && adev->current_call_output != NULL) {
+                ALOGD("BT_SCO OFF during active call, rerouting voice usecases");
+                reassign_device_list(&adev->current_call_output->device_list,
+                                     AUDIO_DEVICE_OUT_EARPIECE, "");
+                voice_update_devices_for_all_voice_usecases(adev);
+            }
             audio_extn_sco_reset_configuration();
         }
     }
